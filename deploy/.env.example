# -----------------------------------------------------------------------------
# Example environment for running the containerized app locally with Postgres.
#
#   cp deploy/.env.example .env      # then edit .env and set your Groq key
#
# The copied ".env" lives at the repo root and is git-ignored — NEVER commit real
# secrets. This file holds placeholders only.
# -----------------------------------------------------------------------------

# --- Postgres (used by the "db" service) ---
POSTGRES_DB=triagebot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres        # change for anything beyond local throwaway use

# --- App configuration (ASP.NET Core reads these via the "__" separator) ---
# Points at the "db" service on the internal Compose network. Keep the username /
# password in sync with the POSTGRES_* values above.
ConnectionStrings__TriageBotDb=Host=db;Port=5432;Database=triagebot;Username=postgres;Password=postgres

# Default LLM provider in the container. Groq is a fast OpenAI-compatible cloud model.
Ai__DefaultProvider=Groq

# REQUIRED for Groq: get a key at https://console.groq.com/keys — do NOT paste it into
# any committed file. Put the real value only in your local ".env".
Groq__ApiKey=REPLACE_WITH_YOUR_GROQ_API_KEY

# Apply EF Core migrations on startup so the app is usable immediately (single instance).
# Set to false in real deployments and run migrations as a separate step/job.
RunMigrationsOnStartup=true

# Optional Azure Application Insights APM. Leave empty to disable telemetry.
APPLICATIONINSIGHTS_CONNECTION_STRING=
