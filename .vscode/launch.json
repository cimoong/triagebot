{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug TriageBot.Web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-web",
      "program": "${workspaceFolder}/src/TriageBot.Web/bin/Debug/net10.0/TriageBot.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/TriageBot.Web",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5227",
        "Logging__LogLevel__Microsoft.EntityFrameworkCore": "Warning"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "Debug TriageBot.Web (Gemini provider)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-web",
      "program": "${workspaceFolder}/src/TriageBot.Web/bin/Debug/net10.0/TriageBot.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/TriageBot.Web",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5227",
        "Ai__DefaultProvider": "Gemini",
        "Logging__LogLevel__Microsoft.EntityFrameworkCore": "Warning"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "Attach to process",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
